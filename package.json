{
  "name": "honor-api",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "tsx src/server.js",
    "dev": "dotenv -e .env.development -- tsx watch src/server.js",
    "dev:migrate": "dotenv -e .env.development -- npx prisma migrate dev",
    "dev:seed": "dotenv -e .env.development -- tsx prisma/seed.ts",
    "dev:studio": "dotenv -e .env.development -- npx prisma studio",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
